{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Rebuild and restart compose deployment",
      "type": "shell",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Run compose down with volume removal",
        "Run compose up with container build"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
    },
    {
      "label": "Rebuild and restart compose deployment with test profile",
      "type": "shell",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Run compose down with volume removal",
        "Run compose up with container build and test profile"
      ],
      "group": {
        "kind": "test",
        "isDefault": true
      },
    },
    {
      "label": "Run compose up with container build",
      "type": "docker-compose",
      "dockerCompose": {
        "up": {
          "detached": false,
          "build": true,
        },
        "files": [
          "${workspaceFolder}/compose.yml"
        ]
      }
    },
    {
      "label": "Run compose up with container build and test profile",
      "type": "docker-compose",
      "dockerCompose": {
        "up": {
          "detached": false,
          "build": true,
          "profiles": ["test"]
        },
        "files": [
          "${workspaceFolder}/compose.yml"
        ]
      }
    },
    {
      "label": "Run compose down with volume removal",
      "type": "docker-compose",
      "dockerCompose": {
        "down": {
            "removeVolumes": true
        },
        "files": [
          "${workspaceFolder}/compose.yml"
        ]
      }
    }
  ]
}
